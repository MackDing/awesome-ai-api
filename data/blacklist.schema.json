{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "awesome-ai-api blacklist",
  "type": "object",
  "required": ["entries"],
  "properties": {
    "$schema": { "type": "string" },
    "updated": { "type": "string", "format": "date" },
    "policy": {
      "type": "object",
      "additionalProperties": true
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/definitions/entry" }
    }
  },
  "definitions": {
    "entry": {
      "type": "object",
      "required": ["slug", "url", "severity", "reported", "summary", "evidence"],
      "properties": {
        "slug":      { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "url":       { "type": "string", "format": "uri" },
        "severity": {
          "type": "string",
          "enum": ["rug_pull", "fake_models", "data_leak", "unauthorized_charge", "banned_upstream"]
        },
        "reported":  { "type": "string", "format": "date" },
        "summary":   { "type": "string", "maxLength": 280 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["source", "link"],
            "properties": {
              "source": { "type": "string" },
              "link":   { "type": "string" },
              "note":   { "type": "string" }
            }
          }
        },
        "operator_response": {
          "type": "object",
          "properties": {
            "responded": { "type": "boolean" },
            "link":      { "type": "string" },
            "date":      { "type": "string", "format": "date" }
          }
        },
        "resolved":  { "type": "boolean" },
        "resolved_note": { "type": "string" }
      }
    }
  }
}
